{
  "openapi": "3.0.3",
  "info": {
    "title": "Verizon Mock API",
    "version": "1.1.0",
    "description": "Mock backend used by Verizon assistant actions"
  },
  "servers": [
    {
      "url": "https://verizon-mock-api-1.onrender.com"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Service health",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "service": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "ok",
                    "service"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/auth": {
      "post": {
        "operationId": "authenticateUser",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "phone": {
                    "type": "string"
                  }
                },
                "required": [
                  "phone"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Authenticated user",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "authenticated": {
                      "type": "boolean"
                    },
                    "account_id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "authenticated",
                    "account_id",
                    "name"
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Authentication failed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "authenticated": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "authenticated"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/billing/{account_id}": {
      "get": {
        "operationId": "getBillingData",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Billing summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "current_amount": {
                      "type": "number"
                    },
                    "due_date": {
                      "type": "string"
                    },
                    "last_month": {
                      "type": "number"
                    },
                    "breakdown": {
                      "type": "object",
                      "properties": {
                        "plan": {
                          "type": "number"
                        },
                        "device_installment": {
                          "type": "number"
                        },
                        "international_roaming": {
                          "type": "number"
                        },
                        "late_fee": {
                          "type": "number"
                        }
                      }
                    }
                  },
                  "required": [
                    "current_amount",
                    "due_date",
                    "last_month",
                    "breakdown"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Account not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/billing/card/{account_id}": {
      "get": {
        "operationId": "getBillingCardData",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Card-style billing payload for assistant responses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "generic": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    }
                  },
                  "required": [
                    "generic"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Account not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/billing/card-values/{account_id}": {
      "get": {
        "operationId": "getBillingCardValues",
        "parameters": [
          {
            "name": "account_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Minimal values for Watson-side card rendering",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "account_id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "bill_card_values": {
                      "type": "object",
                      "properties": {
                        "total_due": {
                          "type": "string"
                        },
                        "due_date": {
                          "type": "string"
                        },
                        "new_charges": {
                          "type": "string"
                        },
                        "last_bill": {
                          "type": "string"
                        },
                        "plan_line": {
                          "type": "string"
                        },
                        "admin_fee": {
                          "type": "string"
                        },
                        "hotspot": {
                          "type": "string"
                        },
                        "taxes": {
                          "type": "string"
                        },
                        "what_increased": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "total_due",
                        "due_date",
                        "new_charges",
                        "last_bill",
                        "plan_line",
                        "admin_fee",
                        "hotspot",
                        "taxes",
                        "what_increased"
                      ]
                    }
                  },
                  "required": [
                    "account_id",
                    "name",
                    "bill_card_values"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Account not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "error"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/plan/current": {
      "get": {
        "operationId": "getCurrentPlan",
        "responses": {
          "200": {
            "description": "Current plan",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "plan": {
                      "type": "string"
                    },
                    "price": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "plan",
                    "price"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/plan/eligible": {
      "get": {
        "operationId": "getEligiblePlans",
        "responses": {
          "200": {
            "description": "Eligible upgrade plans",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "eligible": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "price": {
                            "type": "number"
                          }
                        },
                        "required": [
                          "name",
                          "price"
                        ]
                      }
                    }
                  },
                  "required": [
                    "eligible"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/network/diagnostics": {
      "post": {
        "operationId": "runNetworkDiagnostics",
        "responses": {
          "200": {
            "description": "Diagnostics result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string"
                    },
                    "eta": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "status",
                    "eta"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}